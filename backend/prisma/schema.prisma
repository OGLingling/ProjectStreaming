generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  releaseDate DateTime
  rating      Float    @default(0.0)
  imageUrl    String?
  category    String?
  type         String?  @default("hollywood")
  createdAt   DateTime @default(now())
  videoUrl    String?
}

enum PlanType {
  basico
  estandar
  premium
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  profilePic String? @default("assets/avatars/usuario5.webp")
  createdAt DateTime @default(now())
  plan      String @default("basico")
  isVerified Boolean @default(false)
  pin          String?
  pinExpiresAt DateTime?
}
