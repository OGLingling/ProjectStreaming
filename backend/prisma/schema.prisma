generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Content {
  id           Int      @id @default(autoincrement())
  tmdbId       String?  @unique @map("tmdb_id")
  title        String
  description  String?  @db.Text
  releaseDate  String?
  
  // Visuales
  imageUrl     String?
  backdropUrl  String?
  trailerUrl   String?  @map("trailer_url")
  
  // Clasificación y Tipo
  category     String?
  type         String   @default("movie") // "movie" o "tv"
  rating       Float    @default(0.0)
  
  // Relaciones
  seasons      Season[]
  watchlist    Watchlist[] // Relación con "Mi Lista"

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt 

  @@index([title]) 
}

// Modelo para "Mi Lista" (Antes Favoritos)
model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  contentId Int
  content   Content  @relation(fields: [contentId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, contentId]) // Evita duplicados en la lista
}

model Season {
  id           Int       @id @default(autoincrement())
  seasonNumber Int
  title        String?
  tmdbId       String?   @unique @map("tmdb_id")
  
  contentId    Int
  content      Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes     Episode[]

  createdAt    DateTime  @default(now())
}

model Episode {
  id            Int      @id @default(autoincrement())
  episodeNumber Int
  title         String
  description   String?  @db.Text
  stillPath     String?
  videoUrl      String?
  duration      String?
  
  seasonId      Int
  season        Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
}

enum PlanType {
  basico
  estandar
  premium
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?   @default("123456")
  name      String
  profilePic String? @default("assets/avatars/usuario5.webp")
  createdAt DateTime @default(now())
  plan      PlanType @default(basico)
  isVerified Boolean @default(false)
  pin          String?
  pinExpiresAt DateTime?
  language          String  @default("es")
  parentalPin       String?
  maturityLevel     String  @default("18+")
  subtitleSize      String  @default("medium")
  autoPlay          Boolean @default(true)
  myList        Watchlist[]
}

// Modelo para logs de scraping
model ScrapeLog {
  id          Int      @id @default(autoincrement())
  targetUrl   String   @db.Text
  success     Boolean
  streamUrl   String?  @db.Text
  error       String?  @db.Text
  duration    Int?     // Duración en milisegundos
  createdAt   DateTime @default(now())
  
  @@index([targetUrl])
  @@index([success])
  @@index([createdAt])
}
