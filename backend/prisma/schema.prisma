generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id           Int      @id @default(autoincrement())
  tmdbId       String?  @unique @map("tmdb_id")
  imdbId       String?  @unique @map("imdb_id") 
  title        String
  description  String?  @db.Text
  releaseDate  String?
  // Visuales
  imageUrl     String?
  backdropUrl  String?
  // Clasificación
  category     String?
  type         String   @default("movie")
  // Metadatos de Negocio
  addonId      Int?
  addon        Addon?   @relation(fields: [addonId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt // Estándar Pro para auditoría de cambios
  @@index([title]) // Índice adicional si planeas implementar un buscador
}

model Addon {
  id        Int      @id @default(autoincrement())
  name      String
  baseUrl   String   @unique
  movies    Movie[]  // Relación: Un addon puede tener muchas pelis guardadas
  createdAt DateTime @default(now())
}

enum PlanType {
  basico
  estandar
  premium
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?   @default("123456")
  name      String
  profilePic String? @default("assets/avatars/usuario5.webp")
  createdAt DateTime @default(now())
  plan      PlanType @default(basico)
  isVerified Boolean @default(false)
  pin          String?
  pinExpiresAt DateTime?
  language          String  @default("es")
  parentalPin       String?
  maturityLevel     String  @default("18+")
  subtitleSize      String  @default("medium")
  autoPlay          Boolean @default(true)
}
