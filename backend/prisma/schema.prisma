generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  releaseDate DateTime
  rating      Float    @default(0.0)
  imageUrl    String?
  backdropUrl String?
  category    String?
  type        String
  createdAt   DateTime @default(now())
  videoUrl    String?
}

enum PlanType {
  basico
  estandar
  premium
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   @default("123456")
  name      String
  profilePic String? @default("assets/avatars/usuario5.webp")
  createdAt DateTime @default(now())
  plan      PlanType @default(basico)
  isVerified Boolean @default(false)
  pin          String?
  pinExpiresAt DateTime?
  language          String  @default("es")
  parentalPin       String?
  maturityLevel     String  @default("18+")
  subtitleSize      String  @default("medium")
  autoPlay          Boolean @default(true)
}
